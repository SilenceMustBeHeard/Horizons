@using Horizons.Web.ViewModels.Destination
@model DestinationEditInputModel

@{
    ViewData["Title"] = "Edit Destination";
}

<h2>@ViewData["Title"]</h2>
<hr />

<div class="row">
    <div class="col-md-8 offset-md-2">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="PublishedOn" /> 

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ImageUrl" class="form-label">Image URL</label>
                <input asp-for="ImageUrl" class="form-control" placeholder="Optional" />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TerrainId" class="form-label">Select Terrain</label>
                <select asp-for="TerrainId" class="form-control" asp-items="@(new SelectList(Model.Terrains, "Id", "Name"))">
                    <option value="">-- Select Terrain --</option>
                </select>
                <span asp-validation-for="TerrainId" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                <i class="fas fa-save"></i> Save Changes
            </button>
        </form>
    </div>
</div>
