@using Horizons.Web.ViewModels.Destination
@model IEnumerable<DestinationIndexViewModel>

@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="welcome-section text-center py-5">
    <div class="container">
        <h1>Explore the World with Horizons</h1>
        <p class="lead">Discover amazing destinations, add them to your favorites, and start your adventure today!</p>
        <a asp-controller="Destination" asp-action="Index" class="btn btn-primary btn-lg mt-3">Start Exploring</a>
    </div>
</section>

<!-- Featured Destinations -->
<section class="explore-section py-5">
    <div class="container">
        <h2 class="section-title text-center mb-4">Featured Destinations</h2>
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var dest in Model.Take(6))
            {
                <div class="col">
                    <div class="card hover-scale h-100 shadow-sm">
                        <img src="@(string.IsNullOrEmpty(dest.ImageUrl) ? "~/images/default-image.jpg" : dest.ImageUrl)"
                             class="card-img-top" style="height:200px; object-fit:cover;" alt="@dest.Name" />
                        <div class="card-body text-center">
                            <h5 class="card-title">@dest.Name</h5>
                            <p class="text-muted">@dest.TerrainName</p>

                            <div class="d-flex justify-content-center gap-2 mt-2">
                                <a asp-action="Details" asp-route-id="@dest.Id" class="btn btn-sm btn-primary">
                                    View
                                </a>

                                @if (User.Identity.IsAuthenticated)
                                {
                                    if (!dest.IsUserPublisher)
                                    {
                                        if (!dest.IsUserFavourite)
                                        {
                                            <form asp-action="AddToFavorites" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@dest.Id" />
                                                <button type="submit" class="btn btn-warning btn-sm btn-heart">
                                                    ❤️
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="RemoveFromFavorites" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@dest.Id" />
                                                <button type="submit" class="btn btn-danger btn-sm btn-heart active-heart">
                                                    💔
                                                </button>
                                            </form>
                                        }
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
