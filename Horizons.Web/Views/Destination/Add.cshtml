@using Horizons.Web.ViewModels.Destination
@model DestinationAddInputModel

@{
    ViewData["Title"] = "Add Destination";
}

<div class="d-flex justify-content-between align-items-center mb-3" style="margin-top: 20px;">
    <h2>@ViewData["Title"]</h2>
</div>
<hr />

<div class="row">
    <div class="col-sm-12 offset-lg-2 col-lg-8 offset-xl-3 col-xl-6">
        <form asp-action="Add" method="post">

            <div class="row">
                <div class="col-sm-6 mb-2">
                    <label asp-for="Name" class="form-label-add-edit"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="col-sm-6 mb-2">
                    <label asp-for="TerrainId" class="form-label-add-edit"></label>
                    <select asp-for="TerrainId"
                            class="form-control"
                            asp-items="@(new SelectList(Model.Terrains, "Id", "Name"))">
                        <option value="">...</option>
                    </select>
                    <span asp-validation-for="TerrainId" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-2">
                <label asp-for="Description" class="form-label-add-edit"></label>
                <textarea asp-for="Description" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-2">
                <label asp-for="ImageUrl" class="form-label-add-edit"></label>
                <input asp-for="ImageUrl" class="form-control" />
            </div>

            <div class="mb-2">
                <label asp-for="PublishedOn" class="form-label-add-edit"></label>
                <input asp-for="PublishedOn" class="form-control" type="date" />
                <span asp-validation-for="PublishedOn" class="text-danger"></span>
            </div>

            <button class="btn btn-warning w-100">Save</button>
        </form>
    </div>
</div>
